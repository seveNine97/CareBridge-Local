{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CareBridge Local",
  "version": "0.1.0",
  "identifier": "com.carebridge.local",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CareBridge Local",
        "width": 1280,
        "height": 840,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": []
  }
}
